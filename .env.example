# 阿里云灵积配置（必填）
# 获取地址：https://bailian.console.aliyun.com/cn-beijing/?tab=model#/api-key
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 嵌入模型（选填，默认 tongyi-embedding-vision-plus）
# 可选值：tongyi-embedding-vision-plus, text-embedding-v1, text-embedding-v2
# DASHSCOPE_EMBEDDING_MODEL=tongyi-embedding-vision-plus
